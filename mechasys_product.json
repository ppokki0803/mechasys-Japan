k */\n    .o_footer_copyright p {\n        display: none !important;\n    }\n    \n    /* Overwrite the cookie display button style */\n    .o_cookies_bar_toggle {\n        background-color: #0047bb;\n    }\n    .o_cookies_bar_toggle:hover {\n        background-color: #003d9f !important;\n    }\n    .o_cookies_bar_toggle:active {\n        background-color: #003d9f !important;\n    }\n    \n    \n    /* 1. Float the checkbox to the left (for the forms) */\n    .form-check {\n        float: left; \n        width: auto !important;\n        margin-right: 10px; /* Space between checkbox and text */\n        margin-top: 2px;    /* Slight adjustment to align with text height */\n    }\n    \n    /* 2. Create a flexible column for the text description (for the forms) */\n    .form-check + .s_website_form_field_description {\n        display: block !important; \n        overflow: hidden; /* This magic trick forces the text to stay in its own column */\n        width: auto !important;\n    }\n    \n    /* 3. Ensure the paragraph inside has no extra margins affecting layout (for the form) */\n    .form-check + .s_website_form_field_description p {\n        margin: 0 !important;\n    }\n    \n    /* Adjust Footer */\n    @media (max-width: 991px) {\n        #connect, .pb24.col-lg-8, .o_footer_copyright_name { text-align: center !important; width: 100% !important; }\n        #connect img, .pb24.col-lg-8 img { display: inline-block !important; margin: 0 auto !important; width: 200px !important; height: auto !important; }\n        .s_social_media, .col-sm.d-flex { justify-content: center !important; display: flex !important; width: 100% !important; flex-direction: column !important; }\n        .s_social_media { flex-direction: row !important; }\n    }\n</style>\n\n<script>\n    document.addEventListener(\"DOMContentLoaded\", function() {\n        // configuration: \"Odoo Field Name\": \"Browser Autocomplete Value\"\n        const fieldMappings = {\n            'x_studio_lead_first